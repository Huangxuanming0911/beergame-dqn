{
  "env": {
    "num_firms": 3,
    "prices": [10, 9, 8],
    "holding_cost": 0.5,
    "lost_sales_cost": 2.0,
    "initial_inventory": 100,
    "poisson_lambda": 10,
    "max_steps": 100,
    "max_order": 20,
    "seed": 42
  },
  "experiment": {
    "firm_id": 1,
    "eval_episodes": 20,
    "train_seeds": [42, 123, 456],
    "output_dir": "results/baselines",
    "figure_dir": "figures/baselines",
    "model_dir": "models/baselines"
  },
  "baselines": {
    "base_stock_target": 100
  },
  "algorithms": [
    {"name": "dqn", "network_type": "standard", "double_dqn": false},
    {"name": "double_dqn", "network_type": "standard", "double_dqn": true},
    {"name": "dueling_dqn", "network_type": "dueling", "double_dqn": false},
    {"name": "dueling_double_dqn", "network_type": "dueling", "double_dqn": true},
    {"name": "ppo", "type": "ppo"}
  ],
  "dqn": {
    "episodes": 300,
    "hidden_size": 64,
    "buffer_size": 10000,
    "batch_size": 64,
    "gamma": 0.99,
    "learning_rate": 0.001,
    "tau": 0.001,
    "update_every": 4,
    "eps_start": 1.0,
    "eps_end": 0.05,
    "eps_decay": 0.99,
    "log_every": 50,
    "plot_window": 50,
    "seed": 42
  },
  "ppo": {
    "episodes": 1000,
    "hidden_size": 256,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "learning_rate": 0.0003,
    "clip_epsilon": 0.2,
    "value_coef": 0.5,
    "entropy_coef": 0.05,
    "update_epochs": 10,
    "max_grad_norm": 0.5,
    "target_kl": 0.015,
    "rollout_episodes": 8,
    "reward_scale": 0.001,
    "use_reward_norm": true,
    "use_state_norm": true,
    "use_value_clip": true,
    "use_lr_decay": true,
    "use_entropy_decay": true,
    "log_every": 100,
    "eval_every": 50,
    "eval_episodes": 20,
    "seed": 42
  },
  "background_experiment": {
    "seed": 42,
    "model_dir": "models/background",
    "output_dir": "results/background",
    "figure_dir": "figures/background"
  },
  "multiagent": {
    "episodes": 600,
    "seed": 42,
    "eval_every": 50,
    "eval_episodes": 20,
    "model_dir": "models/multiagent",
    "output_dir": "results/multiagent",
    "figure_dir": "figures/multiagent"
  }
}
